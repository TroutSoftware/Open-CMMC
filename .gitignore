# --- CMMC fork additions ---------------------------------------------------
#
# Keep personal info, deployment-specific values, and credentials OUT of
# the committed tree. Operators stage these in their own configuration
# management tool (Ansible / Terraform / Vault), not here.

# Build artifacts from the FIPS toolchain
/filebrowser-fips
/filebrowser-nofips
/filebrowser-*

# Environment / secrets — anything that might carry OIDC client secrets,
# Keycloak admin passwords, SMTP auth, TPM/HSM PINs, or chain-key
# overrides. The canonical `.env.local` / `.env.*.local` above covers
# frontend; these cover the backend + ops layer.
/.env
/.env.*
*.env
environment
environment.*
/config/**/49-cmmc-vars.conf
/config/**/*-vars.conf
/config/**/*.local.*

# Tokens / session-JWT dumps produced by dev helpers (mint.go etc.)
*.tok
/admin.tok
/user.tok

# PKI / key material. Production keys MUST live under /etc/pki/cmmc on
# the host, never in the repo.
*.pem
*.key
*.crt
*.p12
*.pfx
/pki/
/certs/

# Coverage / profiler output
coverage.out
coverage.html
*.cover
/pprof/
/profiles/

# Local audit-stream samples — they contain real user activity and
# CUI-adjacent metadata.
/audit-samples/
*.jsonl.local
/var/log/cmmc-filebrowser-mirror.*

# Operator logs / snapshots
fb-fips.log
fb-*.log

# Site-local systemd drop-ins overriding defaults with real paths /
# credentials. Commit the canonical unit; operator adds .d/ overrides.
/config/systemd/*.local.service
/config/systemd/*.d/

# Dev scratch — ad-hoc test scripts, temp Go programs, local DB copies
/scratch/
/mint.go
/fipscheck.go
filebrowser.db*
/tmp-*

# Local-only development helpers — not published to TroutSoftware/Open-CMMC.
/config/dev/
/config/fresh-install.sh
