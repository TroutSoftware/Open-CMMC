<!--
  Wazuh rules for CMMC-filebrowser audit events.

  Rule IDs sit in the 200000-200999 custom range. Wazuh built-in
  rules use 1-99999. Install to /var/ossec/etc/rules/ and restart
  the manager:

      sudo install -m 0644 filebrowser-cmmc.xml \
           /var/ossec/etc/rules/
      sudo systemctl restart wazuh-manager

  Severity mapping:
    level 3   — informational "it happened" records (logins,
                file reads), useful for post-incident reconstruction
                but should not page anyone.
    level 5   — authorized rejects (403 from authz, 429 from rate
                limit). Interesting in aggregate, not individually.
    level 8   — authenticated failures that indicate user confusion
                or policy friction (stale MFA reject, failed login).
    level 10  — security-relevant rejects that warrant review but
                are inside the compliance rails (CUI move blocked,
                rate limit exhaustion, session idle lock).
    level 12  — high-severity security events that should page:
                malicious-code detection (3.14.2), audit chain
                break (3.3.8), mark orphan (3.8.4 inconsistency),
                repeated login failures from same source.
    level 14  — incidents requiring immediate response: bypass
                attempts, repeated chain failures.

  CMMC control anchors are named inline via <description> and the
  <group> tag so a CMMC correlation rule can filter by control.
-->

<group name="filebrowser-cmmc,cmmc-l2">

  <!-- Umbrella rule: any structured event we recognize. Child rules
       inherit from this so a global mute / route rule can target
       everything from filebrowser-cmmc in one place. -->
  <rule id="200000" level="0">
    <decoded_as>filebrowser-cmmc</decoded_as>
    <description>filebrowser-cmmc audit event</description>
  </rule>

  <!-- ===== Authentication & session (3.5.x, 3.1.11) ================ -->

  <rule id="200010" level="3">
    <if_sid>200000</if_sid>
    <field name="action">^auth\.login\.ok$</field>
    <description>filebrowser: successful login ($(username))</description>
    <group>authentication_success,cmmc-3.5.3</group>
  </rule>

  <rule id="200011" level="8">
    <if_sid>200000</if_sid>
    <field name="action">^auth\.login\.fail$</field>
    <description>filebrowser: login failed for ($(username))</description>
    <group>authentication_failed,cmmc-3.1.8</group>
  </rule>

  <!-- Correlation rules use <same_field>client_ip</same_field>,
       not <same_source_ip />, because the JSON decoder emits
       client_ip (not srcip). Description placeholders read the
       decoded field directly. -->
  <rule id="200012" level="12" frequency="5" timeframe="60">
    <if_matched_sid>200011</if_matched_sid>
    <same_field>client_ip</same_field>
    <description>filebrowser: brute-force login attempt ($(client_ip))</description>
    <group>authentication_failures,cmmc-3.1.8</group>
  </rule>

  <rule id="200013" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^session\.idle\.lock$</field>
    <description>filebrowser: session idle-locked for ($(username))</description>
    <group>session_termination,cmmc-3.10.2,cmmc-3.1.11</group>
  </rule>

  <rule id="200014" level="3">
    <if_sid>200000</if_sid>
    <field name="action">^auth\.logout$</field>
    <description>filebrowser: logout ($(username))</description>
    <group>session_termination,cmmc-3.1.11</group>
  </rule>

  <rule id="200015" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^auth\.ratelimit\.block$</field>
    <description>filebrowser: login rate-limit exceeded from ($(client_ip))</description>
    <group>access_denied,cmmc-3.1.8</group>
  </rule>

  <rule id="200016" level="12" frequency="3" timeframe="300">
    <if_matched_sid>200015</if_matched_sid>
    <same_field>client_ip</same_field>
    <description>filebrowser: sustained login rate-limit exhaustion from ($(client_ip))</description>
    <group>access_denied,cmmc-3.1.8,attack</group>
  </rule>

  <rule id="200017" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^authz\.priv\.reject$</field>
    <description>filebrowser: privileged op refused, ($(username)) $(reason)</description>
    <group>access_denied,cmmc-3.1.15,cmmc-3.5.3</group>
  </rule>

  <!-- ===== CUI handling (3.8.4, 3.1.3, 3.1.22, 3.13.4) ============ -->

  <rule id="200030" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.access\.reject$</field>
    <description>filebrowser: CUI access refused ($(resource))</description>
    <group>access_denied,cmmc-3.1.3,cmmc-3.1.22</group>
  </rule>

  <rule id="200031" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.move\.blocked$</field>
    <description>filebrowser: CUI move blocked (containment) ($(resource))</description>
    <group>access_denied,cmmc-3.8.3,cmmc-3.1.3</group>
  </rule>

  <rule id="200032" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.mark\.set$</field>
    <description>filebrowser: CUI classification set ($(resource))</description>
    <group>configuration_change,cmmc-3.8.4</group>
  </rule>

  <rule id="200033" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.mark\.declassify$</field>
    <description>filebrowser: CUI declassified ($(resource))</description>
    <group>configuration_change,cmmc-3.8.4</group>
  </rule>

  <rule id="200034" level="12">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.mark\.orphan$</field>
    <description>filebrowser: CUI mark orphaned (rename/copy/delete inconsistency) ($(resource))</description>
    <group>data_integrity,cmmc-3.8.4</group>
  </rule>

  <!-- ===== Malicious code scanning (3.14.2, 3.14.5) ================ -->

  <rule id="200040" level="12">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.scan\.reject$</field>
    <description>filebrowser: MALWARE DETECTED on upload ($(resource)) $(reason)</description>
    <group>malware,cmmc-3.14.2,attack</group>
  </rule>

  <rule id="200041" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^cui\.scan\.error$</field>
    <description>filebrowser: scanner backend error ($(reason))</description>
    <group>service_availability,cmmc-3.14.2</group>
  </rule>

  <!-- ===== Audit chain integrity (3.3.8) ============================ -->

  <rule id="200050" level="14">
    <if_sid>200000</if_sid>
    <field name="action">^audit\.chain\.verify\.fail$</field>
    <description>filebrowser: AUDIT CHAIN TAMPERED ($(reason))</description>
    <group>audit_integrity,cmmc-3.3.8,attack</group>
  </rule>

  <!-- ===== Public share surface (3.1.22) ============================ -->

  <rule id="200060" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^file\.public_share_access$</field>
    <description>filebrowser: public share accessed ($(resource))</description>
    <group>data_transfer,cmmc-3.1.22</group>
  </rule>

  <rule id="200061" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^share\.ratelimit\.block$</field>
    <description>filebrowser: public share rate-limit exceeded from ($(client_ip))</description>
    <group>access_denied,cmmc-3.1.8,cmmc-3.13.4</group>
  </rule>

  <rule id="200062" level="12" frequency="5" timeframe="300">
    <if_matched_sid>200061</if_matched_sid>
    <same_field>client_ip</same_field>
    <description>filebrowser: share-token brute force suspected from ($(client_ip))</description>
    <group>access_denied,cmmc-3.13.4,attack</group>
  </rule>

  <!-- ===== Administrative surface (3.1.5, 3.1.7) ==================== -->

  <rule id="200070" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^user\.create$</field>
    <description>filebrowser: user created ($(resource))</description>
    <group>account_created,cmmc-3.1.5</group>
  </rule>

  <rule id="200071" level="10">
    <if_sid>200000</if_sid>
    <field name="action">^user\.delete$</field>
    <description>filebrowser: user deleted ($(resource))</description>
    <group>account_deleted,cmmc-3.1.5</group>
  </rule>

  <rule id="200074" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^user\.update$</field>
    <description>filebrowser: user updated ($(resource))</description>
    <group>account_changed,cmmc-3.1.5</group>
  </rule>

  <!-- settings.update moved ABOVE authz.group.set so the severity
       ladder reflects blast radius: a group→role remap (200072)
       redirects authorization for many users at once; a settings
       edit (200073) is per-instance. -->
  <rule id="200072" level="8">
    <if_sid>200000</if_sid>
    <field name="action">^authz\.group\.(set|delete)$</field>
    <description>filebrowser: group-role mapping changed ($(resource))</description>
    <group>configuration_change,cmmc-3.1.5,cmmc-3.1.7</group>
  </rule>

  <rule id="200073" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^settings\.update$</field>
    <description>filebrowser: settings changed by ($(username))</description>
    <group>configuration_change,cmmc-3.4.5</group>
  </rule>

  <!-- ===== File operations (3.1.3 / 3.8.3 / 3.13.4) ================ -->

  <rule id="200080" level="3">
    <if_sid>200000</if_sid>
    <field name="action">^file\.upload$</field>
    <description>filebrowser: file uploaded ($(resource))</description>
    <group>file_upload,cmmc-3.1.3</group>
  </rule>

  <rule id="200081" level="3">
    <if_sid>200000</if_sid>
    <field name="action">^file\.download$</field>
    <description>filebrowser: file downloaded ($(resource))</description>
    <group>file_download,cmmc-3.1.3</group>
  </rule>

  <rule id="200082" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^file\.delete$</field>
    <description>filebrowser: file deleted ($(resource))</description>
    <group>file_deleted,cmmc-3.1.3,cmmc-3.8.3</group>
  </rule>

  <rule id="200083" level="3">
    <if_sid>200000</if_sid>
    <field name="action">^file\.(rename|modify)$</field>
    <description>filebrowser: file $(action) ($(resource))</description>
    <group>file_changed,cmmc-3.1.3</group>
  </rule>

  <!-- Burst-download alert: more than 50 distinct download events
       from the same user within 5 min is consistent with a bulk
       exfil attempt. Tune frequency/timeframe per site workload. -->
  <rule id="200084" level="10" frequency="50" timeframe="300">
    <if_matched_sid>200081</if_matched_sid>
    <same_field>user_id</same_field>
    <description>filebrowser: bulk download burst from ($(username))</description>
    <group>data_exfil,cmmc-3.1.3,cmmc-3.13.4</group>
  </rule>

  <!-- ===== Share lifecycle (3.1.22 / 3.13.4) ====================== -->

  <rule id="200090" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^share\.create$</field>
    <description>filebrowser: share link created ($(resource)) by ($(username))</description>
    <group>share_created,cmmc-3.1.22</group>
  </rule>

  <rule id="200091" level="5">
    <if_sid>200000</if_sid>
    <field name="action">^share\.delete$</field>
    <description>filebrowser: share link deleted ($(resource)) by ($(username))</description>
    <group>share_deleted,cmmc-3.1.22</group>
  </rule>

</group>
